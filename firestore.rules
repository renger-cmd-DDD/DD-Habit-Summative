rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidGameState(data) {
      // Data is structured as { state: { ... } }
      return data.keys().hasAny(['state'])
        && data.state is map;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidGameState(request.resource.data);
      allow update: if isOwner(userId) && isValidGameState(request.resource.data);
    }

    match /auth_transfers/{transferId} {
      allow get, read: if isValidId(transferId);
      allow create, update: if isValidId(transferId) && request.resource.data.keys().hasAll(['idToken']);
    }
  }
}
