rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidGameState(data) {
      return data.keys().hasAll(['user', 'habits', 'inventory', 'lastResetDate'])
        && data.user is map
        && data.habits is map
        && data.inventory is list
        && data.lastResetDate is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidGameState(request.resource.data);
      allow update: if isOwner(userId) && isValidGameState(request.resource.data);
    }
  }
}
